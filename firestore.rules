rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Missions Collection
    match /missions/{missionId} {
      // Primitive Helpers
      function isSignedIn() {
        return request.auth != null;
      }

      function isValidId(id) {
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
      }

      function incoming() {
        return request.resource.data;
      }

      function existing() {
        return resource.data;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isCustomBypass(userId) {
        return userId is string && userId.startsWith('custom_') && userId.size() <= 256;
      }

      function isAdmin() {
        return isSignedIn() && request.auth.token.email == 'arijitgarai05@gmail.com' && request.auth.token.email_verified == true;
      }

      // Main Entity Validator
      function isValidMission(data) {
        return data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 256
          && data.goal is string && data.goal.size() <= 2000
          && data.status is string && (data.status == 'active' || data.status == 'completed' || data.status == 'abandoned' || data.status == 'archived')
          && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 128))
          && (!('tasks' in data) || (data.tasks is list && data.tasks.size() <= 100))
          && (!('milestones' in data) || (data.milestones is list && data.milestones.size() <= 50))
          && (!('decisionLog' in data) || (data.decisionLog is list && data.decisionLog.size() <= 200))
          && (!('notifications' in data) || (data.notifications is list && data.notifications.size() <= 100));
      }

      // Allow reads (get/list)
      allow read: if (
        isValidId(missionId) && (
          isOwner(resource.data.userId) ||
          isCustomBypass(resource.data.userId) ||
          isAdmin()
        )
      );

      // Allow create
      allow create: if (
        isValidId(missionId) &&
        isValidMission(incoming()) && (
          isOwner(incoming().userId) ||
          isCustomBypass(incoming().userId) ||
          isAdmin()
        )
      );

      // Allow update
      allow update: if (
        isValidId(missionId) &&
        isValidMission(incoming()) && (
          isOwner(existing().userId) ||
          isCustomBypass(existing().userId) ||
          isAdmin()
        ) && (
          incoming().userId == existing().userId &&
          incoming().id == existing().id
        )
      );

      // Allow delete
      allow delete: if (
        isValidId(missionId) && (
          isOwner(existing().userId) ||
          isCustomBypass(existing().userId) ||
          isAdmin()
        )
      );
    }
  }
}
